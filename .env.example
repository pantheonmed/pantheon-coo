# ══════════════════════════════════════════════════════
#  Pantheon COO OS v2 — Environment Config
#  Copy to .env and fill in values.
#  All commented lines show defaults.
# ══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ports (isolated, no conflicts) ─────────────
PORT=8002                  # backend API
HOST=0.0.0.0
FRONTEND_PORT=3002         # dashboard static server
FRONTEND_HOST=0.0.0.0

# ── AI models ─────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-5
# CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# ── Phase 4 — OpenAI fallback (optional) ──────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini
# ENABLE_FALLBACK=true

# ── Database ──────────────────────────────────────────
# DB_PATH=pantheon_v2.db

# ── Agent loop tuning ─────────────────────────────────
# MAX_LOOP_ITERATIONS=5
# MIN_EVAL_SCORE=0.75
# AGENT_TIMEOUT_SECONDS=90

# ── Workspace ─────────────────────────────────────────
# WORKSPACE_DIR=/tmp/pantheon_v2

# ── Performance monitoring ────────────────────────────
# MONITOR_INTERVAL_SECONDS=300
# ALERT_SCORE_THRESHOLD=0.60
# ALERT_FAILURE_RATE=0.40
# PROMPT_OPTIMIZE_AFTER=10

# ── WhatsApp (optional) ───────────────────────────────
# WHATSAPP_VERIFY_TOKEN=your-secret
# WHATSAPP_ACCESS_TOKEN=your-meta-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# ── Email (optional) ──────────────────────────────────
# EMAIL_BACKEND=smtp
# EMAIL_FROM=coo@pantheon.ai
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# RESEND_API_KEY=re_...

# ── API Authentication ────────────────────────────────────────────
# AUTH_MODE=none              # none (dev) | apikey | jwt (use jwt for multi-user)
# COO_API_KEY=                # legacy static key when AUTH_MODE=apikey
# JWT_SECRET=                 # required in production; required for /auth/login JWT minting
# JWT_EXPIRY_HOURS=168        # default 7 days
# ALLOW_REGISTRATION=true     # set false to disable POST /auth/register
# WHATSAPP_APP_SECRET=        # from Meta App Dashboard (enables webhook sig verification)

# ── Voice (Whisper + TTS; optional) ─────────────────────────────────
# VOICE_ENABLED=false
# Requires OPENAI_API_KEY for Whisper + TTS

# ── Google Sheets (optional) ────────────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# OR paste JSON directly:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SHEETS_SCOPE=https://www.googleapis.com/auth/spreadsheets

# ── Telegram Bot (optional) ─────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=   # optional; use with setWebhook secret_token

# ── Twilio (voice / SMS; optional) ────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# ── Database tool (Postgres/MySQL host allowlist; comma-separated) ─
# DATABASE_WHITELIST=db.example.com,another.db.internal

# ── PostgreSQL (optional — empty DATABASE_URL keeps SQLite store via db_path) ─
# DATABASE_URL=postgresql+asyncpg://pantheon:pantheon_dev@localhost:5433/pantheon_coo
# POSTGRES_STORE_ENABLED=false   # set true only after store SQL is migrated to Postgres
# POSTGRES_PASSWORD=change_in_production   # used by docker compose postgres profile

# ── Auto-deploy (optional) ──────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_USERNAME=
# RAILWAY_TOKEN=
# VERCEL_TOKEN=

# ── Video generation (optional) ───────────────────────────────────
# DID_API_KEY=
# SYNTHESIA_API_KEY=
# VIDEO_GENERATION_ENABLED=false

# ── Notion (optional) ───────────────────────────────────────────────
# NOTION_API_KEY=secret_...

# ── Zoho CRM India (optional) ──────────────────────────────────────
# ZOHO_ACCESS_TOKEN=
# ZOHO_REFRESH_TOKEN=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# Google Calendar uses the same GOOGLE_SERVICE_ACCOUNT_JSON as Sheets; scope:
# GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar

# ── Razorpay (India billing) ───────────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...  # Dashboard → Webhooks → secret

# ── Stripe (global billing, non-INR) ────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Amazon Selling Partner API (optional) ───────────────────────
# AMAZON_ACCESS_KEY=
# AMAZON_SECRET_KEY=
# AMAZON_ROLE_ARN=
# AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# ── Meesho supplier API (optional) ─────────────────────────────
# MEESHO_API_KEY=
# MEESHO_SUPPLIER_ID=

# ── WhatsApp commerce (catalog / orders; optional) ─────────────
# WHATSAPP_CATALOG_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Rate Limiting ─────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60          # global limit per IP (ignored when plan tiers apply)
# RATE_LIMIT_EXECUTE_PER_MINUTE=10  # tighter limit on /execute (ignored when plan tiers apply)

# ── Redis (optional cache + distributed rate limits) ──────────────
# REDIS_URL=redis://localhost:6379/0
# REDIS_ENABLED=false

# ── OpenTelemetry ─────────────────────────────────────────────────
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=pantheon-coo

# ── White-label ───────────────────────────────────────────────────
# WHITE_LABEL_ENABLED=false
# WHITE_LABEL_NAME=Pantheon COO
# WHITE_LABEL_LOGO_URL=
# WHITE_LABEL_PRIMARY_COLOR=#7c6ff7
# WHITE_LABEL_SUPPORT_EMAIL=hello@pantheon.ai
# WHITE_LABEL_DOMAIN=

# ── Affiliate program ─────────────────────────────────────────────
# DEFAULT_AFFILIATE_COMMISSION=20

# ── Tally Prime ─────────────────────────────────────────────────
# TALLY_HOST=localhost
# TALLY_PORT=9000
# TALLY_COMPANY=Pantheon Meditech Private Limited

# ── Zapier inbound webhook (optional) ───────────────────────────
# ZAPIER_WEBHOOK_SECRET=   # send as header X-Zapier-Secret on POST /webhook/zapier

# ── HubSpot CRM (optional) ──────────────────────────────────────
# HUBSPOT_API_KEY=

# ── WordPress REST (optional; application password) ─────────────
# WORDPRESS_SITE_URL=https://yoursite.com
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=

# ── Shopify Admin API (optional) ────────────────────────────────
# SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
# SHOPIFY_ACCESS_TOKEN=

# ── LinkedIn automation (optional; Playwright — use responsibly) ──
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=

# ── Instagram / Twitter (optional) ────────────────────────────
# INSTAGRAM_USERNAME=
# INSTAGRAM_PASSWORD=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# ── Enterprise SAML (stub until full IdP wiring) ────────────────
# SAML_ENABLED=false
# SAML_IDP_METADATA_URL=
# SAML_SP_ENTITY_ID=https://your-domain.com

# ── Distributed task queue (optional scale-out) ─────────────────
# DISTRIBUTED_TASK_QUEUE=false
# WORKER_COUNT=2
# MAX_QUEUE_DEPTH=100
