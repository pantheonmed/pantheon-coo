{
  "manifest_version": 3,
  "name": "Pantheon COO",
  "version": "1.0.0",
  "description": "Run AI commands from any webpage",
  "permissions": ["activeTab", "storage", "notifications", "contextMenus"],
  "host_permissions": ["http://localhost:8002/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
