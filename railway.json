{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn main_railway:app --host 0.0.0.0 --port ${PORT:-8002}",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60
  }
}
